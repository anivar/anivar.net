---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article' | 'profile';
  containerClass?: string;
}

const {
  title,
  description,
  ogType = 'website',
  containerClass = 'container-prose',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle =
  Astro.url.pathname === '/' ? title : `${title} — Anivar A. Aravind`;

const nav = [
  { href: '/about/', label: 'About' },
  { href: '/projects/', label: 'Projects' },
  { href: '/research/', label: 'Research' },
  { href: '/writing/', label: 'Writing' },
  { href: '/talks/', label: 'Talks' },
  { href: '/press/', label: 'Press' },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') + '/';

const personLD = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anivar A. Aravind',
  alternateName: 'Anivar',
  url: 'https://anivar.net',
  image: 'https://anivar.net/portrait.jpg',
  jobTitle: 'Engineering leader and systems thinker',
  email: 'mailto:ping@anivar.net',
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'ORCID',
    value: '0009-0009-8995-0005',
    url: 'https://orcid.org/0009-0009-8995-0005',
  },
  sameAs: [
    'https://orcid.org/0009-0009-8995-0005',
    'https://github.com/anivar',
    'https://www.linkedin.com/in/anivar/',
    'https://thelayer8.substack.com',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/atom+xml" title="Anivar A. Aravind — Writing & Research" href="/feed.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="anivar.net" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#0b0e14" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f5f0" media="(prefers-color-scheme: light)" />

    <script type="application/ld+json" set:html={JSON.stringify(personLD)} />
  </head>

  <body>
    <a href="#main" class="skip">Skip to content</a>

    <div class="shell">
      <header class="site-header">
        <div class="container-wide site-header__inner">
          <a href="/" class="site-header__brand">Anivar A. Aravind</a>
          <nav class="site-nav" aria-label="Primary">
            {
              nav.map((item) => (
                <a
                  href={item.href}
                  aria-current={currentPath === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </header>

      <main id="main" class={containerClass}>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container-wide site-footer__inner">
          <span>
            &copy; {new Date().getFullYear()} Anivar A. Aravind. Site copy under{' '}
            <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>;
            papers under <a href="https://creativecommons.org/publicdomain/zero/1.0/">CC0</a>.
          </span>
          <span>
            <a href="mailto:ping@anivar.net">ping@anivar.net</a>{' · '}
            <a href="https://github.com/anivar">GitHub</a>{' · '}
            <a href="https://www.linkedin.com/in/anivar/">LinkedIn</a>{' · '}
            <a href="https://thelayer8.substack.com">Layer 8</a>{' · '}
            <a href="/feed.xml">RSS</a>
          </span>
        </div>
      </footer>
    </div>
  </body>
</html>
