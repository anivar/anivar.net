---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Projects';
const description =
  'A continuing line of independent work alongside two decades of engineering leadership. Current and previous projects on free software, public computing, AI infrastructure, and digital governance.';

interface Entry {
  year: string;
  name: string;
  href?: string;
  role: string;
  status: 'current' | 'concluded' | 'continuing';
  body: string;
  tags: string[];
}

const entries: Entry[] = [
  {
    year: '2025–',
    name: 'OpenSLM.ai — Open Small Models Accord',
    href: 'https://openslm.ai',
    role: 'Founder · Initiator',
    status: 'current',
    body:
      'A standards-style document setting out ten principles for open, accessible, and correctable small language models, with reference tooling and evaluation. The accord answers the gap left by open-weights releases that are inspectable in name only — open weights without affordable retraining is permission to inspect a system you can never reproduce. OpenSLM publishes the principles, the evaluation harness, and a JSON Schema for accord-conformant disclosures.',
    tags: ['AI · Open Source · Standards · LWD-R'],
  },
  {
    year: '2025–',
    name: 'Corrigibility framework',
    href: '/corrigibility/',
    role: 'Author',
    status: 'current',
    body:
      'A falsifiable structural standard for whether digital and learned public infrastructure can be corrected by the people it governs. Five jointly necessary tests — EXIT, CODE, AUDIT, GOVERN, FORK — derived from cybernetics (Ashby), commons governance (Ostrom), and free-software principles. Two papers on Zenodo: a deterministic-DPI paper (Paper I, on SSRN) and a learned/agentic EPI paper (Paper II). A schema repository operationalises the framework as a falsifiable protocol.',
    tags: ['Public Infrastructure · Cybernetics · Commons · FOSS'],
  },
  {
    year: '2024–',
    name: 'Layer 8',
    href: 'https://thelayer8.substack.com',
    role: 'Author',
    status: 'current',
    body:
      'A research letter on standards, identity, AI infrastructure, and how power, incentives, and governance get encoded into them. Layer 8 reads at the seam between technical specifications and the political economy that ships them — what a protocol concedes, who benefits from the concession, and what corrective surfaces it leaves intact.',
    tags: ['Newsletter · Standards · Governance'],
  },
  {
    year: '2014–2020s',
    name: 'Indic Project',
    href: 'https://indicproject.org',
    role: 'Founder · Coordinator',
    status: 'concluded',
    body:
      'A free-software collective for Indian-language computing — Indic Keyboard (Android, used at scale across south Asian languages), Varnam (transliteration), Dhvani (text-to-speech), and LibIndic (Python toolkit for Indic NLP). The Indic Project shipped under-served language affordances when the platforms did not, and pushed standards bodies to recognise them. Concluded as a coordinated collective; individual projects continue independently.',
    tags: ['Free Software · Indic NLP · Public Computing'],
  },
  {
    year: '2003–',
    name: 'Swathanthra Malayalam Computing (SMC)',
    href: 'https://smc.org.in',
    role: 'Contributor',
    status: 'continuing',
    body:
      'A long-running community for Malayalam computing — fonts, input methods, locale data, and language tooling. Contributor since the early 2000s. Work upstream into Unicode, fontconfig, and rendering stacks. SMC is the longest-running of the lines on this page.',
    tags: ['Free Software · Malayalam · Unicode'],
  },
  {
    year: '2003–',
    name: 'Earlier — selected',
    role: 'Contributor · Initiator',
    status: 'continuing',
    body:
      'Net neutrality interventions during the Save the Internet campaign. Aadhaar interventions on enrolment coercion and reversibility. Contribution to BIS IS 16333 (Part 3) — India\'s national standard for Indic-language computing. ICANN57 fellowship, with continuing upstream work at Unicode, IDNA, and ICANN. ECMAScript 2025 work on Mozilla Rhino.',
    tags: ['Net Neutrality · Aadhaar · Standards · Internet Governance'],
  },
];

const statusLabel: Record<Entry['status'], string> = {
  current: 'Current',
  concluded: 'Concluded',
  continuing: 'Continuing',
};
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <article>
    <header class="hd">
      <span class="kicker">Projects</span>
      <h1>A continuing line of independent work.</h1>
      <p class="lede">
        Alongside two decades of engineering leadership, a record of free
        software, multilingual public computing, AI infrastructure, and
        digital governance. Reverse chronological.
      </p>
    </header>

    <ol class="proj-list">
      {
        entries.map((e) => (
          <li class="proj">
            <div class="proj__year" aria-hidden="true">{e.year}</div>
            <div class="proj__main">
              <h2 class="proj__name">
                {e.href ? <a href={e.href}>{e.name}</a> : e.name}
              </h2>
              <p class="proj__meta">
                <span class={`proj__status proj__status--${e.status}`}>{statusLabel[e.status]}</span>
                <span class="proj__sep" aria-hidden="true">·</span>
                <span class="proj__role">{e.role}</span>
              </p>
              <p class="proj__body">{e.body}</p>
              <p class="proj__tags">{e.tags.join(' · ')}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </article>
</BaseLayout>

<style>
  .hd {
    max-width: var(--measure-prose);
    margin-bottom: 3rem;
  }

  .proj-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--line);
  }

  .proj {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding-block: 2rem;
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 820px) {
    .proj {
      grid-template-columns: 7rem 1fr;
      gap: 2.5rem;
    }
  }

  .proj__year {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--ink-3);
    padding-top: 0.4rem;
    letter-spacing: 0.01em;
  }

  .proj__main {
    max-width: 56rem;
  }

  .proj__name {
    font-family: var(--serif);
    font-size: 1.375rem;
    font-weight: 500;
    margin: 0 0 0.4rem;
    line-height: 1.25;
  }

  .proj__name a {
    text-decoration: none;
    color: var(--ink);
  }

  .proj__name a:hover {
    color: var(--accent);
  }

  .proj__meta {
    font-family: var(--sans);
    font-size: 0.8125rem;
    letter-spacing: 0.01em;
    margin: 0 0 0.85rem;
    color: var(--ink-3);
  }

  .proj__status {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.6875rem;
  }

  .proj__status--current {
    color: var(--accent);
  }

  .proj__status--concluded {
    color: var(--ink-3);
  }

  .proj__status--continuing {
    color: var(--ink-2);
  }

  .proj__sep {
    margin-inline: 0.5rem;
    color: var(--ink-4);
  }

  .proj__body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink);
    margin: 0 0 0.85rem;
  }

  .proj__tags {
    font-family: var(--sans);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
  }
</style>
