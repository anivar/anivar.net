---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Anivar A. Aravind';
const description =
  'Engineering leader and systems thinker. Two decades across regulated FinTech, B2B2C global commerce, and multilingual public computing used by hundreds of millions. A continuing line of independent work at OpenSLM.ai, Corrigibility, and Layer 8.';
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <section class="hero">
    <div class="hero__text">
      <span class="kicker">Engineering · Systems · Governance</span>
      <h1>Anivar A. Aravind</h1>
      <p class="hero__sub">Engineering leader. Systems thinker.</p>
      <p class="hero__lede">
        Two decades across regulated FinTech, B2B2C global commerce, and
        multilingual public computing used by hundreds of millions. A continuing
        line of independent work at <a href="https://openslm.ai">OpenSLM.ai</a>,
        <a href="/corrigibility/">Corrigibility</a>, and
        <a href="https://thelayer8.substack.com">Layer 8</a>.
      </p>
      <div class="cta-row">
        <a href="/projects/" class="btn btn-primary">See the work →</a>
        <a href="https://thelayer8.substack.com" class="btn">Subscribe — Layer 8 →</a>
      </div>
      <p class="hero__mailto"><a href="mailto:ping@anivar.net">ping@anivar.net</a></p>
    </div>
    <div class="hero__portrait" aria-hidden="true">
      <div class="hero__portrait-frame">
        <span class="tail">portrait.jpg</span>
      </div>
    </div>
  </section>

  <section class="now-elsewhere">
    <div class="two-col">
      <div>
        <p class="two-col__head">Now</p>
        <ul class="bullet">
          <li>Enterprise AI transformation — agentic governance, context and memory, production evaluation.</li>
          <li>OpenSLM.ai — Open Small Models Accord and tooling.</li>
          <li>Corrigibility — working papers on corrigible deterministic and learned public infrastructure.</li>
          <li>Selective advisory.</li>
        </ul>
      </div>
      <div>
        <p class="two-col__head">Elsewhere</p>
        <ul class="plain-links">
          <li><a href="https://thelayer8.substack.com">Layer 8 (Substack)</a></li>
          <li><a href="https://github.com/anivar">GitHub</a></li>
          <li><a href="https://www.linkedin.com/in/anivar/">LinkedIn</a></li>
          <li><a href="https://x.com/anivar">X</a></li>
          <li><a href="https://orcid.org/0009-0009-8995-0005">ORCID 0009-0009-8995-0005</a></li>
          <li><a href="https://zenodo.org/communities/openslm/">Zenodo</a></li>
          <li><a href="/feed.xml">RSS</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section aria-labelledby="operating-range">
    <h2 id="operating-range" class="section-h">Operating range</h2>
    <ul class="t-list">
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Regulated FinTech</span>
          <p class="t-list__body">RBI NBFC. SVP Engineering through 3.75&times; growth, one product to five. Audit-grade controls designed in by default.</p>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Global commerce (B2B2C)</span>
          <p class="t-list__body">Multi-tenant SaaS, marketplace, and payments across six markets. PCI&nbsp;DSS, PSD2/SCA, 3DS. 10,000+ branded apps on a shared platform.</p>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Population-scale public computing</span>
          <p class="t-list__body">Contributor to BIS&nbsp;IS&nbsp;16333 (Part&nbsp;3), India's standard for Indic-language computing — used by hundreds of millions.</p>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">AI as a first-class layer</span>
          <p class="t-list__body">Agentic systems in regulated production. Governance, memory, and workflow boundaries built in.</p>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Multi-site engineering orgs</span>
          <p class="t-list__body">UK and India. Hiring, levelling, performance, succession. Rebuilt orgs under growth and cost pressure.</p>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">M&amp;A and technical diligence</span>
          <p class="t-list__body">Both sides of the table.</p>
        </div>
      </li>
    </ul>
  </section>

  <section aria-labelledby="working-ideas">
    <h2 id="working-ideas" class="section-h">Working ideas</h2>

    <p class="eyebrow eyebrow--row">Currently</p>
    <ul class="t-list">
      <li>
        <div class="t-list__row">
          <span class="t-list__label">OpenSLM.ai</span>
          <div class="t-list__body">
            <strong>Open Small Models Accord.</strong> Ten principles for open, accessible, correctable small language models, with tooling and evaluation. <a href="https://openslm.ai">openslm.ai →</a>
          </div>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Corrigibility</span>
          <div class="t-list__body">
            <strong>Corrigibility framework.</strong> A falsifiable standard for whether digital and learned public infrastructure can be corrected by the people it governs. Two papers on Zenodo. <a href="/corrigibility/">/corrigibility/ →</a>
          </div>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Layer 8</span>
          <div class="t-list__body">
            <strong>Layer 8.</strong> A research letter on standards, identity, AI infrastructure, and how power, incentives, and governance get encoded into them. <a href="https://thelayer8.substack.com">thelayer8.substack.com →</a>
          </div>
        </div>
      </li>
    </ul>

    <p class="eyebrow eyebrow--row">Previously</p>
    <ul class="t-list">
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Indic Project</span>
          <div class="t-list__body">
            Free and open-source Indian-language technology — Indic Keyboard, Varnam, Dhvani, LibIndic. Concluded as a coordinated collective; projects continue independently. <a href="https://indicproject.org">indicproject.org →</a>
          </div>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">SMC</span>
          <div class="t-list__body">
            <strong>Swathanthra Malayalam Computing.</strong> Long-running community for Malayalam computing, contributor since the early 2000s.
          </div>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Earlier</span>
          <div class="t-list__body">
            …and others, going back to 2003 — net neutrality, Aadhaar interventions, BIS&nbsp;IS&nbsp;16333 contribution, ICANN57 fellowship. <a href="/projects/">See /projects/ →</a>
          </div>
        </div>
      </li>
    </ul>
  </section>

  <section class="coverage" aria-labelledby="coverage">
    <h2 id="coverage" class="section-h">Selected coverage</h2>
    <ul class="t-list">
      <li>
        <div class="t-list__row">
          <span class="t-list__label">MIT Tech Review</span>
          <p class="t-list__body">Featured commentary on Aadhaar and population-scale identity infrastructure.</p>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">The Hindu</span>
          <p class="t-list__body">Quoted on Indic-language computing standards and digital public infrastructure.</p>
        </div>
      </li>
      <li>
        <div class="t-list__row">
          <span class="t-list__label">Deccan Herald</span>
          <p class="t-list__body">Recognised as a Changemaker (2024) for sustained work on accountable digital infrastructure.</p>
        </div>
      </li>
    </ul>
    <p class="see-all"><a href="/press/">See all coverage →</a></p>
  </section>

  <section class="trust" aria-label="Recognition">
    <p class="trust__line">
      Recognised by <strong>Deccan Herald</strong> as a Changemaker (2024) ·
      <strong>SFLC.in</strong> advisory board ·
      <strong>Just AI Awards</strong> jury, 2024 &amp; 2025.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    padding-block: clamp(2rem, 6vw, 4rem);
  }

  @media (min-width: 880px) {
    .hero {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      gap: clamp(2.5rem, 6vw, 5rem);
    }
  }

  .hero__sub {
    font-family: var(--serif);
    font-size: clamp(1.25rem, 2.6vw, 1.625rem);
    color: var(--ink-2);
    margin: 0.25rem 0 1.5rem;
    font-style: italic;
  }

  .hero__lede {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--ink);
    max-width: 38rem;
  }

  .hero__mailto {
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--ink-3);
  }

  .hero__mailto a {
    color: var(--ink-2);
    text-decoration-color: var(--ink-4);
  }

  .hero__portrait {
    display: flex;
    justify-content: center;
  }

  .hero__portrait-frame {
    aspect-ratio: 1 / 1;
    width: min(100%, 320px);
    border: 1px solid var(--line-2);
    background: linear-gradient(180deg, var(--bg-rise), var(--bg-sink));
    display: grid;
    place-items: center;
    color: var(--ink-4);
    font-family: var(--mono);
    font-size: 0.75rem;
    border-radius: 4px;
  }

  .section-h {
    border-top: 1px solid var(--line);
    padding-top: 2rem;
    margin-top: 0;
  }

  .eyebrow--row {
    display: block;
    margin: 2rem 0 0.75rem;
  }

  .bullet,
  .plain-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .bullet > li {
    padding-left: 1rem;
    position: relative;
    margin-bottom: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .bullet > li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .plain-links > li {
    margin-bottom: 0.4rem;
    font-size: 0.9375rem;
  }

  .see-all {
    margin-top: 1.5rem;
    font-size: 0.9375rem;
  }

  .trust__line {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--ink-2);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: 1.25rem;
  }
</style>
