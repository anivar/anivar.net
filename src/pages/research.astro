---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Research';
const description =
  'Working papers, frameworks, and citation page. Corrigibility framework (Paper I — DPI; Paper II — EPI) and the Open Small Models Accord.';
---

<BaseLayout title={title} description={description}>
  <article>
    <header>
      <span class="kicker">Research</span>
      <h1>Working papers and frameworks.</h1>
      <p class="lede">
        An independent line of work on infrastructure that can be inspected,
        reproduced, and corrected. All papers under CC0; preprints on SSRN and
        Zenodo with citable identifiers.
      </p>
    </header>

    <section aria-labelledby="corrigibility">
      <h2 id="corrigibility">The Corrigibility framework</h2>
      <p>
        A two-paper structural standard for whether digital and learned public
        infrastructure can be corrected by the people it governs. Five jointly
        necessary tests — EXIT, CODE, AUDIT, GOVERN, FORK — derived from
        cybernetics, commons governance, and free-software principles.
      </p>

      <ul class="t-list">
        <li>
          <div class="t-list__row">
            <span class="t-list__label">Paper I · DPI</span>
            <div class="t-list__body">
              <strong>Corrigibility as a Structural Precondition for Digital Public Infrastructure: A Cybernetic Framework.</strong>
              50 pages. SSRN preprint.
              <p class="paper-meta">
                <a href="https://doi.org/10.2139/ssrn.6059075">doi.org/10.2139/ssrn.6059075</a>
                <span class="sep" aria-hidden="true">·</span>
                <a href="/corrigibility/corrigibility-framework-dpi.pdf">PDF</a>
                <span class="sep" aria-hidden="true">·</span>
                <a href="/corrigibility/">Read /corrigibility/ →</a>
              </p>
            </div>
          </div>
        </li>
        <li>
          <div class="t-list__row">
            <span class="t-list__label">Paper II · EPI</span>
            <div class="t-list__body">
              <strong>Epistemic Capture and the Action Boundary: Corrigibility for Learned and Agentic Public Infrastructure.</strong>
              32 pages. Zenodo preprint.
              <p class="paper-meta">
                <a href="https://doi.org/10.5281/zenodo.19863649">doi.org/10.5281/zenodo.19863649</a>
                <span class="sep" aria-hidden="true">·</span>
                <a href="/corrigibility/corrigibility-framework-ai.pdf">PDF</a>
              </p>
            </div>
          </div>
        </li>
      </ul>
    </section>

    <section aria-labelledby="accord">
      <h2 id="accord">The Open Small Models Accord</h2>
      <p>
        Ten principles for open, accessible, and correctable small language
        models, with reference tooling and evaluation. Hosted at
        <a href="https://openslm.ai/accord">openslm.ai/accord</a>.
      </p>
    </section>

    <section aria-labelledby="cite">
      <h2 id="cite">Cite</h2>
      <p>BibTeX for both papers, with copy-on-click coming soon.</p>
      <pre class="bib"><code>@article{`{`}aravind2026dpi,
  author = {`{`}Aravind, Anivar A.{`}`},
  title  = {`{`}Corrigibility as a Structural Precondition for
            Digital Public Infrastructure: A Cybernetic Framework{`}`},
  year   = {`{`}2026{`}`},
  doi    = {`{`}10.2139/ssrn.6059075{`}`},
  url    = {`{`}https://doi.org/10.2139/ssrn.6059075{`}`},
  license = {`{`}CC0-1.0{`}`}
{`}`}

@article{`{`}aravind2026epi,
  author = {`{`}Aravind, Anivar A.{`}`},
  title  = {`{`}Epistemic Capture and the Action Boundary:
            Corrigibility for Learned and Agentic Public Infrastructure{`}`},
  year   = {`{`}2026{`}`},
  doi    = {`{`}10.5281/zenodo.19863649{`}`},
  url    = {`{`}https://doi.org/10.5281/zenodo.19863649{`}`},
  license = {`{`}CC0-1.0{`}`}
{`}`}</code></pre>
    </section>
  </article>
</BaseLayout>

<style>
  .paper-meta {
    margin-top: 0.6rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--ink-2);
  }
  .paper-meta a {
    color: var(--ink-2);
  }
  .paper-meta a:hover {
    color: var(--accent);
  }
  .sep {
    margin-inline: 0.5rem;
    color: var(--ink-4);
  }
  .bib {
    background: var(--bg-rise);
    border: 1px solid var(--line);
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--ink-2);
  }
</style>
