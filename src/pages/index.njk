---
layout: layouts/base.njk
isHome: true
permalink: /index.html
---
<article class="home">

  <section class="hero">
    <p class="eyebrow">Engineering · Systems · Governance</p>
    <h1>Anivar A. Aravind</h1>
    <p class="positioning">Engineering leadership and systems thinking for technology that has to ship commercially, hold up under regulator and board scrutiny, and reach population scale at once.</p>

    <p class="subline"><strong>Twenty-year engineering leader.</strong> Global commerce, RBI-regulated FinTech, multilingual public computing. Platforms used by hundreds of millions.</p>
    <p class="subline"><strong>Systems thinker</strong> on AI governance, public-sector technology, and the human layer of software.</p>

    <p class="identity-strip">
      {% for tag in site.identityStrip %}{{ tag }}{% if not loop.last %} <span class="sep" aria-hidden="true">·</span> {% endif %}{% endfor %}
    </p>

    <p class="hero-cta">
      <a href="/about/">About</a>
      <a href="/contact/">Get in touch</a>
    </p>
  </section>

  <section aria-labelledby="op">
    <h2 id="op">Operating Range</h2>
    <ul class="t-list">
      {% set currently = log | byCareerGroup('currently') %}
      {% set recent = log | byCareerGroup('recent') %}
      {% set earlier = log | byCareerGroup('earlier') %}
      {% set standards = log | byCareerGroup('standards') %}
      {% if currently.length %}
        <li class="group-label">Currently</li>
        <li><ul class="rows">{% for r in currently %}<li><span class="role">{{ r.title }}{% if r.org %}, {{ r.org }}{% endif %}</span><span class="span">{{ r | spanLabel }}</span></li>{% endfor %}</ul></li>
      {% endif %}
      {% if recent.length %}
        <li class="group-label">Recent</li>
        <li><ul class="rows">{% for r in recent | reverse %}<li><span class="role">{{ r.title }}{% if r.org %}, {{ r.org }}{% endif %}</span><span class="span">{{ r | spanLabel }}</span></li>{% endfor %}</ul></li>
      {% endif %}
      {% if earlier.length %}
        <li class="group-label">Earlier</li>
        <li><ul class="rows">{% for r in earlier %}<li><span class="role">{{ r.title }}{% if r.org %}, {{ r.org }}{% endif %}</span><span class="span">{{ r | spanLabel }}</span></li>{% endfor %}</ul></li>
      {% endif %}
      {% if standards.length %}
        <li class="group-label">Standards &amp; policy</li>
        <li><ul class="rows">{% for r in standards | reverse %}<li><span class="role">{{ r.title }}{% if r.org %}, {{ r.org }}{% endif %}</span><span class="span">{{ r | spanLabel }}</span></li>{% endfor %}</ul></li>
      {% endif %}
    </ul>
  </section>

  <section aria-labelledby="wi">
    <h2 id="wi">Long-running work</h2>
    <ul class="wi-list">
      {% for w in log | byTheme('collective') %}
        <li>
          <p class="name">{{ w.title }}</p>
          <div class="body">
            <p class="scope">{{ w.scope }}</p>
            <p class="desc">{{ w.role }} · {{ w | spanLabel }}</p>
            <p class="link"><a href="{{ w.external or w.internalHref }}">{{ (w.external or w.internalHref) | replace("https://", "") | replace("http://", "") }}</a></p>
          </div>
        </li>
      {% endfor %}
    </ul>
    <p class="muted"><a href="/projects/">Independent projects and writing →</a></p>
  </section>

  <section aria-labelledby="recog">
    <h2 id="recog">Selected Recognition</h2>
    <ul class="recog">
      {% for r in log | byKinds('award,standard,fellowship') | limit(5) %}
        <li>
          <span>
            <span class="label">{{ r.title }}{% if r.org %} — {{ r.org }}{% endif %}</span>
            {% if r.blurb %}<span class="context">{{ r.blurb }}</span>{% endif %}
          </span>
          <span class="year">{{ r | spanLabel }}</span>
        </li>
      {% endfor %}
    </ul>
    <p class="muted"><a href="/history/">Full chronology →</a> · <a href="/press/">Press kit →</a></p>
  </section>

  <section aria-labelledby="now">
    <h2 id="now">Now <span class="muted" style="font-weight:400;font-size:0.9rem">— as of {{ now.asOf | dateLong }}</span></h2>
    <ul class="now-list">
      {% for item in now.items %}<li>{{ item }}</li>{% endfor %}
    </ul>
    <p class="muted"><a href="/now/">More on /now/ →</a></p>
  </section>

  <section aria-labelledby="contact-strip">
    <h2 id="contact-strip">Contact</h2>
    <p>
      <a href="mailto:{{ site.email.general }}">{{ site.email.general }}</a> ·
      <a href="{{ site.elsewhere.linkedin }}">LinkedIn</a> ·
      <a href="{{ site.elsewhere.github }}">GitHub</a> ·
      <a href="{{ site.elsewhere.substack }}">Substack</a> ·
      <a href="{{ site.elsewhere.orcid }}" rel="me">ORCID</a>
    </p>
    <p class="muted">Three lanes — media, advisory, research — at <a href="/contact/">/contact/</a>.</p>
  </section>

</article>
