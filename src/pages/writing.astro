---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Writing';
const description =
  'Selected long-form writing and an archive mirror of Layer 8 — a research letter on standards, identity, AI infrastructure, and how power, incentives, and governance get encoded into them.';
---

<BaseLayout title={title} description={description}>
  <article>
    <header>
      <span class="kicker">Writing</span>
      <h1>Layer 8 and selected long-form.</h1>
      <p class="lede">
        Layer 8 is a research letter on standards, identity, AI infrastructure,
        and how power, incentives, and governance get encoded into them. New
        posts go out on
        <a href="https://thelayer8.substack.com">thelayer8.substack.com</a>;
        an archive mirror lives here.
      </p>
    </header>

    <section>
      <h2>Subscribe</h2>
      <p>
        Layer 8 lives on Substack — there is no signup widget on this site.
        <a href="https://thelayer8.substack.com" class="btn btn-primary" style="margin-top: 1rem;">Subscribe on Substack →</a>
      </p>
    </section>

    <section>
      <h2>Archive</h2>
      <p class="tail">
        [pending — automated mirror of the Layer 8 RSS feed will populate this
        section at build time. Until then, read the full archive at
        <a href="https://thelayer8.substack.com/archive">thelayer8.substack.com/archive</a>.]
      </p>
    </section>
  </article>
</BaseLayout>
